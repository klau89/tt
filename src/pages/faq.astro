---
import Layout from '../layouts/Layout.astro';

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Do I need a membership?', acceptedAnswer: { '@type': 'Answer', text: 'No. You pay for the bay by the hour, and that’s the whole deal. Book once or book every day — up to you.' } },
    { '@type': 'Question', name: 'I’ve never played. Is this for me?', acceptedAnswer: { '@type': 'Answer', text: 'Perfect. The ball machine is the friendliest way to start — set it slow, hit a hundred balls, no one watching. Beginners are exactly who we built this for.' } },
    { '@type': 'Question', name: 'Tennis or pickleball — how do I choose?', acceptedAnswer: { '@type': 'Answer', text: 'You pick your sport when you book. Every bay converts between the two, so we set it up before you arrive. Want both? Book back-to-back and we’ll switch it over.' } },
    { '@type': 'Question', name: 'What do I need to bring?', acceptedAnswer: { '@type': 'Answer', text: 'Just yourself and sneakers with a clean sole. We keep loaner racquets, paddles and balls on-site at no charge.' } },
    { '@type': 'Question', name: 'How does the door unlock?', acceptedAnswer: { '@type': 'Answer', text: 'When you book, we text you a code and a tap-to-unlock link that goes live at your start time. Walk up, tap, and you’re in.' } },
    { '@type': 'Question', name: 'Can I bring friends or my kids?', acceptedAnswer: { '@type': 'Answer', text: 'Absolutely. A bay fits up to four, and the price is the same whether it’s just you or a full group.' } },
    { '@type': 'Question', name: 'What if I need to cancel?', acceptedAnswer: { '@type': 'Answer', text: 'Cancel up to 12 hours before your slot for a full refund, right from the same link we texted you.' } },
    { '@type': 'Question', name: 'Is there parking?', acceptedAnswer: { '@type': 'Answer', text: 'We’re built for ferry, bike and subway, with Citi Bike docks and racks nearby. Street parking along the waterfront is limited, so allow extra time if driving.' } },
  ],
};
---
<Layout
  title="FAQ | Tennis Terminal"
  description="Everything to know before your first hit — membership, beginners, gear, unlocking the door, bringing friends, cancellations and parking."
  path="/faq"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline></script>

  <section style="max-width:820px;margin:0 auto;padding:clamp(48px,7vw,84px) 24px clamp(24px,4vw,40px);text-align:center">
    <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:16px">FAQ</div>
    <h1 style="font-size:clamp(38px,5.4vw,60px);line-height:1.04">Good questions</h1>
    <p style="font-family:var(--font-body);font-size:clamp(17px,2.2vw,20px);line-height:1.6;color:var(--tt-ink-700);margin:20px auto 0;max-width:46ch;text-wrap:pretty">Everything you might wonder before your first hit. Can't find it? <a href="mailto:hey@tennisterminal.com">Just ask us.</a></p>
  </section>

  <section style="max-width:820px;margin:0 auto;padding:clamp(16px,3vw,24px) 24px clamp(48px,7vw,84px)">
    <div style="display:flex;flex-direction:column;gap:12px">
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">Do I need a membership?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Nope. Never. You pay for the bay by the hour, and that's the whole deal. Book once or book every day — up to you.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">I've never played. Is this for me?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Perfect. The ball machine is the friendliest way to start — set it slow, hit a hundred balls, no one watching. Beginners are exactly who we built this for.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">Tennis or pickleball — how do I choose?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">You pick your sport when you book. Every bay converts between the two, so we set it up — net height and lines — before you arrive. Want both in one session? Book back-to-back and we'll switch it over.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">What do I need to bring?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Just yourself and sneakers with a clean sole. We keep loaner racquets, paddles and balls on-site at no charge, so you can show up empty-handed and still play.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">How does the door unlock?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">When you book, we text you a code and a tap-to-unlock link that goes live at your start time. Walk up, tap, and you're in — the lights and your bay are already set.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">Can I bring friends or my kids?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Absolutely. A bay fits up to four, and the price is the same whether it's just you or a full group. Family sessions are some of our favorites.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">What if I need to cancel?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Life happens. Cancel up to 12 hours before your slot for a full refund, right from the same link we texted you.</p></details>
      <details style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px"><summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">Is there parking?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary><p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">We're built for ferry, bike and subway — there's a Citi Bike dock and racks right outside. Street parking along the waterfront is limited, so give yourself a few extra minutes if you're driving.</p></details>
    </div>
  </section>

  <section style="background:var(--tt-play-green)">
    <div style="max-width:820px;margin:0 auto;padding:clamp(48px,7vw,80px) 24px;text-align:center">
      <h2 style="font-size:clamp(28px,4vw,40px);line-height:1.1;color:var(--tt-honey-cream)">Still curious?</h2>
      <p style="font-family:var(--font-body);font-size:18px;line-height:1.6;color:var(--tt-honey-cream);opacity:0.9;margin-top:14px">Drop us a line, or join the waitlist and try it yourself.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:26px">
        <a href="mailto:hey@tennisterminal.com" style="display:inline-block;font-family:var(--font-display);font-weight:600;font-size:16px;color:var(--tt-court-ink);background:var(--tt-honey-cream);padding:15px 30px;border-radius:10px">Email us</a>
        <a href="/join" style="display:inline-block;font-family:var(--font-display);font-weight:600;font-size:16px;color:var(--tt-honey-cream);background:transparent;border:1px solid rgba(253,246,230,0.5);padding:15px 30px;border-radius:10px">Join the waitlist</a>
      </div>
    </div>
  </section>
</Layout>
