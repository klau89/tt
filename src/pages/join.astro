---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import WaitlistScript from '../components/WaitlistScript.astro';
---
<Layout
  title="Join the Waitlist | Tennis Terminal"
  description="Be first through the door on the Brooklyn waterfront. Join the Tennis Terminal waitlist — we'll text you the moment the bays open, with a free first hour on us."
  path="/join"
>
  <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:clamp(40px,7vw,80px) 24px">
    <div style="width:100%;max-width:960px;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(28px,5vw,56px);align-items:center">

      <!-- LEFT: pitch -->
      <div>
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:16px">Join the waitlist</div>
        <h1 style="font-size:clamp(34px,4.8vw,52px);line-height:1.04">Be first through the door</h1>
        <p style="font-family:var(--font-body);font-size:clamp(16px,2vw,19px);line-height:1.6;color:var(--tt-ink-700);margin-top:18px;max-width:34ch;text-wrap:pretty">We're opening on the Brooklyn waterfront soon. Get on the list and we'll text you the moment the bays go live.</p>
        <div style="display:flex;flex-direction:column;gap:14px;margin-top:28px">
          <div style="display:flex;gap:12px;align-items:center"><span style="color:var(--tt-play-green);font-family:var(--font-display);font-weight:700;font-size:18px">✓</span><span style="font-family:var(--font-body);font-size:16px;color:var(--tt-ink-700)">A free first hour, on us</span></div>
          <div style="display:flex;gap:12px;align-items:center"><span style="color:var(--tt-play-green);font-family:var(--font-display);font-weight:700;font-size:18px">✓</span><span style="font-family:var(--font-body);font-size:16px;color:var(--tt-ink-700)">Early access before we open to all</span></div>
          <div style="display:flex;gap:12px;align-items:center"><span style="color:var(--tt-play-green);font-family:var(--font-display);font-weight:700;font-size:18px">✓</span><span style="font-family:var(--font-body);font-size:16px;color:var(--tt-ink-700)">No spam — just the one text when we're live</span></div>
        </div>
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--tt-ink-300);margin-top:28px">1,200+ neighbors already waiting</div>
      </div>

      <!-- RIGHT: form / confirmation -->
      <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:18px;padding:clamp(24px,4vw,36px);box-shadow:0 16px 40px rgba(22,59,42,0.1)">
        <WaitlistForm submitLabel="Join the waitlist →" gap="18px" tcpaAlign="center">
          <div slot="success">
            <div style="width:60px;height:60px;position:relative;margin-bottom:20px"><div style="width:100%;height:100%;border-radius:50%;background:var(--tt-play-green)"></div><div style="position:absolute;top:-8%;right:-8%;width:38%;height:38%;border-radius:50%;background:var(--tt-ball-yellow);border:4px solid var(--tt-white)"></div></div>
            <h2 style="font-size:28px;line-height:1.1">You're on the list.</h2>
            <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">You're <strong style="color:var(--tt-court-ink)">#1,247</strong> in line. We'll text the second the bays open — with your free first hour attached.</p>
            <div style="height:1px;background:var(--tt-border);margin:22px 0"></div>
            <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--tt-ink-500);margin-bottom:14px">What happens next</div>
            <div style="display:flex;flex-direction:column;gap:14px">
              <div style="display:flex;gap:14px;align-items:flex-start"><span style="font-family:var(--font-mono);color:var(--tt-play-green);font-size:13px;flex-shrink:0;margin-top:2px">01</span><p style="font-family:var(--font-body);font-size:15px;line-height:1.55;color:var(--tt-ink-700)">We'll email a confirmation to <strong data-fill="email" style="color:var(--tt-court-ink)">you</strong> in a moment.</p></div>
              <div style="display:flex;gap:14px;align-items:flex-start"><span style="font-family:var(--font-mono);color:var(--tt-play-green);font-size:13px;flex-shrink:0;margin-top:2px">02</span><p style="font-family:var(--font-body);font-size:15px;line-height:1.55;color:var(--tt-ink-700)">A few days before we open, you'll get early booking access.</p></div>
              <div style="display:flex;gap:14px;align-items:flex-start"><span style="font-family:var(--font-mono);color:var(--tt-play-green);font-size:13px;flex-shrink:0;margin-top:2px">03</span><p style="font-family:var(--font-body);font-size:15px;line-height:1.55;color:var(--tt-ink-700)">Book, unlock, play. Your first hour's free.</p></div>
            </div>
            <div style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:12px;padding:18px;margin-top:22px">
              <div style="font-family:var(--font-display);font-weight:600;font-size:15px;color:var(--tt-court-ink)">Jump the line</div>
              <p style="font-family:var(--font-body);font-size:14px;line-height:1.5;color:var(--tt-ink-700);margin-top:4px">Refer a friend and you both move up. Share your link:</p>
              <div style="display:flex;gap:8px;margin-top:12px">
                <input readonly data-fill="referral" value="tennisterminal.com/r/you" class="tt-input" style="font-size:14px;padding:11px 14px" />
                <button type="button" data-copy style="font-family:var(--font-display);font-weight:600;font-size:14px;color:var(--color-primary-on);background:var(--tt-play-green);border:none;border-radius:10px;padding:0 18px;cursor:pointer;white-space:nowrap">Copy</button>
              </div>
            </div>
            <a href="/how-it-works" style="display:block;text-align:center;font-family:var(--font-display);font-weight:600;font-size:15px;color:var(--tt-court-ink);margin-top:22px">While you wait — see how it works →</a>
          </div>
        </WaitlistForm>
      </div>
    </div>
  </div>

  <WaitlistScript />
</Layout>
