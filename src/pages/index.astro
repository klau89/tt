---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import WaitlistScript from '../components/WaitlistScript.astro';
---
<Layout
  title="Indoor Tennis & Pickleball on the Brooklyn Waterfront | Tennis Terminal"
  description="Self-serve indoor tennis & pickleball on the Brooklyn waterfront. Book a bay on your phone, unlock the door, and play. No membership, ever."
  path="/"
>
  <!-- ===================== HERO ===================== -->
  <section id="top" style="position:relative;max-width:1120px;margin:0 auto;padding:clamp(48px,8vw,96px) 24px clamp(40px,6vw,72px)">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:clamp(32px,5vw,64px);align-items:center">
      <div style="position:relative;z-index:2">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-ink-300);margin-bottom:22px">Brooklyn waterfront · opening soon</div>
        <h1 style="font-size:clamp(38px,5.4vw,62px);line-height:1.02;color:var(--tt-court-ink)">Your court,<br>your schedule.<br><span style="color:var(--tt-play-green);white-space:nowrap">No membership.</span></h1>
        <p style="font-family:var(--font-body);font-size:clamp(17px,2.2vw,20px);line-height:1.6;color:var(--tt-ink-700);margin-top:24px;max-width:30ch;text-wrap:pretty">Book a bay on your phone, unlock the door with your phone, and start the ball machine when you're ready. Tennis or pickleball — 30 seconds from phone to first serve.</p>
        <div style="display:flex;align-items:center;gap:14px;margin-top:22px;flex-wrap:wrap">
          <span style="font-family:var(--font-display);font-weight:600;color:var(--tt-court-ink)">Book · Unlock · Play.</span>
          <span style="font-family:var(--font-body);color:var(--tt-ink-500)">That's it.</span>
        </div>

        <!-- Waitlist form -->
        <div style="margin-top:34px;max-width:440px">
          <WaitlistForm submitLabel="Join the waitlist" gap="14px">
            <div slot="success" style="background:var(--tt-green-100);border:1px solid var(--tt-success-border);border-radius:14px;padding:22px 24px">
              <div style="font-family:var(--font-display);font-weight:700;font-size:19px;color:var(--tt-court-ink)">You're on the list.</div>
              <p style="font-family:var(--font-body);font-size:15px;color:var(--tt-ink-700);margin-top:6px">We'll text you the second the bays open. No spam, promise.</p>
            </div>
          </WaitlistForm>
          <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--tt-ink-300);margin-top:14px">1,200+ neighbors already waiting</div>
        </div>
      </div>

      <!-- Hero image + ball motif -->
      <div style="position:relative;min-height:clamp(320px,42vw,460px)">
        <div style="position:absolute;inset:0;border-radius:18px;overflow:hidden;border:1px solid var(--tt-cream-shade)"><img src="/assets/photos/storefront.png" alt="Two people walking out of the Tennis Terminal storefront with racquets" style="width:100%;height:100%;object-fit:cover;display:block" /></div>
        <div style="position:absolute;top:-28px;right:-28px;width:clamp(90px,14vw,140px);height:clamp(90px,14vw,140px);animation:ttfloat 6s ease-in-out infinite">
          <div style="width:100%;height:100%;border-radius:50%;background:var(--tt-play-green)"></div>
          <div style="position:absolute;top:-8%;right:-8%;width:38%;height:38%;border-radius:50%;background:var(--tt-ball-yellow);border:4px solid var(--tt-honey-cream)"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TRUST STRIP ===================== -->
  <section style="background:var(--tt-court-ink)">
    <div style="max-width:1120px;margin:0 auto;padding:26px 24px;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:22px;text-align:center">
      <div><div style="font-family:var(--font-display);font-weight:700;font-size:30px;color:var(--tt-ball-yellow)">30s</div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-honey-cream);opacity:0.75;margin-top:6px">Phone to first serve</div></div>
      <div><div style="font-family:var(--font-display);font-weight:700;font-size:30px;color:var(--tt-ball-yellow)">7am–11pm</div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-honey-cream);opacity:0.75;margin-top:6px">Every single day</div></div>
      <div><div style="font-family:var(--font-display);font-weight:700;font-size:30px;color:var(--tt-ball-yellow)">$0</div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-honey-cream);opacity:0.75;margin-top:6px">Membership required</div></div>
      <div><div style="font-family:var(--font-display);font-weight:700;font-size:30px;color:var(--tt-ball-yellow)">2 sports</div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-honey-cream);opacity:0.75;margin-top:6px">Tennis &amp; pickleball</div></div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section id="how" style="max-width:1120px;margin:0 auto;padding:clamp(56px,8vw,100px) 24px">
    <div style="text-align:center;max-width:640px;margin:0 auto 48px">
      <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:14px">How it works</div>
      <h2 style="font-size:clamp(32px,4.6vw,44px);line-height:1.08">Three taps and you're playing</h2>
      <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--tt-ink-700);margin-top:16px">No front desk. No sign-in sheet. No waiting on a coach. Just you and the court, whenever it works for you.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:22px">
      <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:30px">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.14em;color:var(--tt-play-green)">01</div>
        <h3 style="font-size:24px;margin-top:14px">Book a bay</h3>
        <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">Pick your sport, pick a time. Reserve in about 30 seconds — no account setup, no membership.</p>
      </div>
      <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:30px">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.14em;color:var(--tt-play-green)">02</div>
        <h3 style="font-size:24px;margin-top:14px">Unlock the door</h3>
        <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">We text you a code. Tap to unlock your bay when you arrive — the lights are already on.</p>
      </div>
      <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:30px">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.14em;color:var(--tt-play-green)">03</div>
        <h3 style="font-size:24px;margin-top:14px">Play</h3>
        <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">Start the ball machine when you're ready. Dial in speed and spin from your phone, and get to work.</p>
      </div>
    </div>
  </section>

  <!-- ===================== PRICING ===================== -->
  <section id="pricing" style="background:var(--tt-white);border-top:1px solid var(--tt-cream-shade);border-bottom:1px solid var(--tt-cream-shade)">
    <div style="max-width:1120px;margin:0 auto;padding:clamp(56px,8vw,100px) 24px">
      <div style="text-align:center;max-width:640px;margin:0 auto 48px">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:14px">Pricing</div>
        <h2 style="font-size:clamp(32px,4.6vw,44px);line-height:1.08">Pay for the time you play</h2>
        <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--tt-ink-700);margin-top:16px">Prices depend on your sport — tennis is a solo ball-machine session, pickleball splits one bay up to four. No membership, ever.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:22px;align-items:stretch">
        <div style="background:var(--tt-court-ink);border-radius:18px;padding:32px;display:flex;flex-direction:column;box-shadow:0 16px 40px rgba(22,59,42,0.18)">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-court-ink);background:var(--tt-ball-yellow);padding:5px 12px;border-radius:999px">Tennis</span>
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--tt-honey-cream);opacity:0.65">Solo practice</span>
          </div>
          <div style="display:flex;gap:28px;margin-top:24px;flex-wrap:wrap">
            <div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--tt-ball-yellow)">Off-peak</div><div style="display:flex;align-items:baseline;gap:3px;margin-top:6px"><span style="font-family:var(--font-display);font-weight:700;font-size:44px;color:var(--tt-honey-cream)">$32</span><span style="font-family:var(--font-body);font-size:15px;color:var(--tt-honey-cream);opacity:0.7">/hr</span></div></div>
            <div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--tt-marigold)">Peak</div><div style="display:flex;align-items:baseline;gap:3px;margin-top:6px"><span style="font-family:var(--font-display);font-weight:700;font-size:44px;color:var(--tt-honey-cream)">$50</span><span style="font-family:var(--font-body);font-size:15px;color:var(--tt-honey-cream);opacity:0.7">/hr</span></div></div>
          </div>
          <div style="height:1px;background:rgba(253,246,230,0.15);margin:22px 0"></div>
          <div style="display:flex;gap:10px;align-items:flex-start"><span style="color:var(--tt-ball-yellow);font-family:var(--font-display);font-weight:700">✓</span><span style="font-family:var(--font-body);font-size:15px;color:var(--tt-honey-cream)">Ball machine included — it's never an upsell</span></div>
        </div>
        <div style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:18px;padding:32px;display:flex;flex-direction:column">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-primary-on);background:var(--tt-play-green);padding:5px 12px;border-radius:999px">Pickleball</span>
            <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--tt-ink-300)">Up to 4 players</span>
          </div>
          <div style="display:flex;gap:28px;margin-top:24px;flex-wrap:wrap">
            <div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--tt-play-green)">Off-peak</div><div style="display:flex;align-items:baseline;gap:3px;margin-top:6px"><span style="font-family:var(--font-display);font-weight:700;font-size:44px;color:var(--tt-court-ink)">$24</span><span style="font-family:var(--font-body);font-size:15px;color:var(--tt-ink-500)">/hr</span></div></div>
            <div><div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--tt-marigold)">Peak</div><div style="display:flex;align-items:baseline;gap:3px;margin-top:6px"><span style="font-family:var(--font-display);font-weight:700;font-size:44px;color:var(--tt-court-ink)">$38</span><span style="font-family:var(--font-body);font-size:15px;color:var(--tt-ink-500)">/hr</span></div></div>
          </div>
          <div style="height:1px;background:var(--tt-border);margin:22px 0"></div>
          <div style="display:flex;gap:10px;align-items:flex-start"><span style="color:var(--tt-play-green);font-family:var(--font-display);font-weight:700">+</span><span style="font-family:var(--font-body);font-size:15px;color:var(--tt-ink-700)">Ball machine optional — <strong style="color:var(--tt-court-ink)">+$8/hr</strong> for solo drilling</span></div>
        </div>
      </div>
      <p style="text-align:center;font-family:var(--font-body);font-size:15px;color:var(--tt-ink-500);margin-top:28px">Racquets and balls on-site if you need them — no charge. <a href="/faq">See the FAQ</a>. <a href="/pricing">Full pricing →</a></p>
    </div>
  </section>

  <!-- ===================== THE SPACE ===================== -->
  <section id="space" style="max-width:1120px;margin:0 auto;padding:clamp(56px,8vw,100px) 24px">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(32px,5vw,56px);align-items:center">
      <div>
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:14px">The space</div>
        <h2 style="font-size:clamp(32px,4.6vw,44px);line-height:1.08">Four bays on the Brooklyn waterfront</h2>
        <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--tt-ink-700);margin-top:18px;text-wrap:pretty">A bright, warm room right on the water — big windows, real cushioned court surface, and enough net height to actually swing. Each bay is yours alone for your booked hour. No sharing, no shuffling on and off.</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:26px">
          <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:12px;padding:16px"><div style="font-family:var(--font-display);font-weight:600;color:var(--tt-court-ink)">Private bays</div><div style="font-family:var(--font-body);font-size:14px;color:var(--tt-ink-500);margin-top:4px">Just your group, every time</div></div>
          <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:12px;padding:16px"><div style="font-family:var(--font-display);font-weight:600;color:var(--tt-court-ink)">Gear on hand</div><div style="font-family:var(--font-body);font-size:14px;color:var(--tt-ink-500);margin-top:4px">Loaner racquets &amp; balls</div></div>
          <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:12px;padding:16px"><div style="font-family:var(--font-display);font-weight:600;color:var(--tt-court-ink)">Ferry &amp; bike close</div><div style="font-family:var(--font-body);font-size:14px;color:var(--tt-ink-500);margin-top:4px">Steps from the waterfront</div></div>
          <div style="background:var(--tt-white);border:1px solid var(--tt-cream-shade);border-radius:12px;padding:16px"><div style="font-family:var(--font-display);font-weight:600;color:var(--tt-court-ink)">Open late</div><div style="font-family:var(--font-body);font-size:14px;color:var(--tt-ink-500);margin-top:4px">7am to 11pm, daily</div></div>
        </div>
      </div>
      <div style="display:grid;grid-template-rows:1.3fr 1fr;gap:16px;min-height:clamp(320px,42vw,440px)">
        <div style="border-radius:18px;overflow:hidden;border:1px solid var(--tt-cream-shade)"><img src="/assets/photos/empty-bay.png" alt="Empty indoor bay at Tennis Terminal with windows onto the Brooklyn waterfront" style="width:100%;height:100%;object-fit:cover;display:block" /></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div style="border-radius:18px;overflow:hidden;border:1px solid var(--tt-cream-shade)"><img src="/assets/photos/unlock.png" alt="A hand tapping a phone to the smart lock on a Tennis Terminal bay door" style="width:100%;height:100%;object-fit:cover;display:block" /></div>
          <div style="border-radius:18px;overflow:hidden;border:1px solid var(--tt-cream-shade)"><img src="/assets/photos/pickleball.png" alt="Two friends sharing a high-five over the net after pickleball at Tennis Terminal" style="width:100%;height:100%;object-fit:cover;display:block" /></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== EVENTS ===================== -->
  <section id="events" style="background:var(--tt-play-green)">
    <div style="max-width:1120px;margin:0 auto;padding:clamp(56px,8vw,100px) 24px">
      <div style="max-width:640px">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-honey-cream);opacity:0.8;margin-bottom:14px">Events &amp; parties</div>
        <h2 style="font-size:clamp(32px,4.6vw,44px);line-height:1.08;color:var(--tt-honey-cream)">Book the whole place out</h2>
        <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--tt-honey-cream);opacity:0.92;margin-top:16px">Birthdays, team offsites, league nights, kid's parties — take over the bays for a couple hours. We'll set up the machines, you bring the crew. Beginners more than welcome.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;margin-top:44px">
        <div style="background:var(--tt-honey-cream);border-radius:18px;padding:28px">
          <h3 style="font-size:22px">Birthday bash</h3>
          <p style="font-family:var(--font-body);font-size:15px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">Two bays, two hours, all the balls you can hit. Great for kids and grown-ups alike.</p>
          <div style="font-family:var(--font-display);font-weight:700;font-size:24px;color:var(--tt-court-ink);margin-top:18px">From $180</div>
        </div>
        <div style="background:var(--tt-honey-cream);border-radius:18px;padding:28px">
          <h3 style="font-size:22px">Team offsite</h3>
          <p style="font-family:var(--font-body);font-size:15px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">Whole-venue buyout for up to 16. A round-robin, a little coaching, zero pressure.</p>
          <div style="font-family:var(--font-display);font-weight:700;font-size:24px;color:var(--tt-court-ink);margin-top:18px">From $360</div>
        </div>
        <div style="background:var(--tt-honey-cream);border-radius:18px;padding:28px">
          <h3 style="font-size:22px">League night</h3>
          <p style="font-family:var(--font-body);font-size:15px;line-height:1.6;color:var(--tt-ink-700);margin-top:10px">Standing weekly slot for your crew. Same bay, same time, locked in for the season.</p>
          <div style="font-family:var(--font-display);font-weight:700;font-size:24px;color:var(--tt-court-ink);margin-top:18px">Ask us</div>
        </div>
      </div>
      <div style="margin-top:36px">
        <a href="/events" style="display:inline-block;font-family:var(--font-display);font-weight:600;font-size:16px;color:var(--tt-court-ink);background:var(--tt-honey-cream);padding:14px 26px;border-radius:10px">Plan an event →</a>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section id="about" style="max-width:1120px;margin:0 auto;padding:clamp(56px,8vw,100px) 24px">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(32px,5vw,64px);align-items:center">
      <div style="position:relative;min-height:clamp(280px,36vw,400px)">
        <div style="position:absolute;inset:0;border-radius:18px;overflow:hidden;border:1px solid var(--tt-cream-shade)"><img src="/assets/photos/family.png" alt="A parent and child beside the ball machine on a Tennis Terminal court" style="width:100%;height:100%;object-fit:cover;display:block" /></div>
        <div style="position:absolute;bottom:-24px;left:-24px;width:clamp(72px,10vw,104px);height:clamp(72px,10vw,104px)">
          <div style="width:100%;height:100%;border-radius:50%;background:var(--tt-court-ink)"></div>
          <div style="position:absolute;top:-8%;right:-8%;width:38%;height:38%;border-radius:50%;background:var(--tt-ball-yellow);border:4px solid var(--tt-honey-cream)"></div>
        </div>
      </div>
      <div>
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:14px">Our story</div>
        <h2 style="font-size:clamp(32px,4.6vw,44px);line-height:1.08">The anti-country-club</h2>
        <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--tt-ink-700);margin-top:18px;text-wrap:pretty">We got tired of courts you had to join a club to touch, coaches you had to book weeks out, and prices that treated a casual hit like a luxury. So we built the opposite.</p>
        <p style="font-family:var(--font-body);font-size:17px;line-height:1.6;color:var(--tt-ink-700);margin-top:16px;text-wrap:pretty">Tennis Terminal is a self-serve practice room where anyone — beginners, families, rusty former players — can walk in, grab a bay, and just play. No membership to belong to. No one watching. Your court, your schedule.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:24px">
          <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-court-ink);background:var(--tt-white);border:1px solid var(--tt-cream-shade);padding:8px 14px;border-radius:999px">Welcoming</span>
          <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-court-ink);background:var(--tt-white);border:1px solid var(--tt-cream-shade);padding:8px 14px;border-radius:999px">Tech-forward</span>
          <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-court-ink);background:var(--tt-white);border:1px solid var(--tt-cream-shade);padding:8px 14px;border-radius:999px">Affordable</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section id="faq" style="background:var(--tt-white);border-top:1px solid var(--tt-cream-shade)">
    <div style="max-width:820px;margin:0 auto;padding:clamp(56px,8vw,100px) 24px">
      <div style="text-align:center;margin-bottom:44px">
        <div style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--tt-play-green);margin-bottom:14px">FAQ</div>
        <h2 style="font-size:clamp(32px,4.6vw,44px);line-height:1.08">Good questions</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <details style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px">
          <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">Do I need a membership?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Nope. Never. You pay for the bay by the hour, and that's the whole deal. Book once or book every day — up to you.</p>
        </details>
        <details style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px">
          <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">I've never played. Is this for me?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Perfect. The ball machine is the friendliest way to start — set it slow, hit a hundred balls, no one watching. Beginners are exactly who we built this for.</p>
        </details>
        <details style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px">
          <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">What do I need to bring?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Just yourself and sneakers with a clean sole. We keep loaner racquets and balls on-site at no charge, so you can show up empty-handed and still play.</p>
        </details>
        <details style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px">
          <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">How does the door unlock?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">When you book, we text you a code and a tap-to-unlock link that goes live at your start time. Walk up, tap, and you're in — the lights and your bay are already set.</p>
        </details>
        <details style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px">
          <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">Can I bring friends or my kids?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Absolutely. A bay fits up to four, and the price is the same whether it's just you or a full group. Family sessions are some of our favorites.</p>
        </details>
        <details style="background:var(--tt-honey-cream);border:1px solid var(--tt-cream-shade);border-radius:14px;padding:4px 22px">
          <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 0"><span style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-court-ink)">What if I need to cancel?</span><span class="tt-faq-plus" style="font-family:var(--font-display);font-size:24px;color:var(--tt-play-green);transition:transform 180ms">+</span></summary>
          <p style="font-family:var(--font-body);font-size:16px;line-height:1.6;color:var(--tt-ink-700);padding:0 0 20px">Life happens. Cancel up to 12 hours before your slot for a full refund, right from the same link we texted you.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section style="background:var(--tt-court-ink)">
    <div style="max-width:820px;margin:0 auto;padding:clamp(56px,8vw,96px) 24px;text-align:center">
      <div style="width:64px;height:64px;margin:0 auto 26px;position:relative">
        <div style="width:100%;height:100%;border-radius:50%;background:var(--tt-play-green)"></div>
        <div style="position:absolute;top:-8%;right:-8%;width:38%;height:38%;border-radius:50%;background:var(--tt-ball-yellow);border:4px solid var(--tt-court-ink)"></div>
      </div>
      <h2 style="font-size:clamp(30px,4.6vw,44px);line-height:1.1;color:var(--tt-honey-cream)">Be first through the door</h2>
      <p style="font-family:var(--font-body);font-size:18px;line-height:1.6;color:var(--tt-honey-cream);opacity:0.85;margin-top:16px">We're opening on the Brooklyn waterfront soon. Join the waitlist and we'll text you the moment the bays go live — plus a free first hour on us.</p>
      <div style="max-width:440px;margin:30px auto 0">
        <div data-waitlist>
          <div data-state="form">
            <form data-waitlist-form style="display:flex;gap:10px;flex-wrap:wrap">
              <input data-field="email" type="email" required placeholder="you@email.com" style="flex:1;min-width:200px;font-family:var(--font-body);font-size:16px;color:var(--tt-court-ink);background:var(--tt-honey-cream);border:1px solid transparent;border-radius:10px;padding:14px 16px;outline:none" />
              <button type="submit" style="font-family:var(--font-display);font-weight:600;font-size:16px;color:var(--tt-court-ink);background:var(--tt-ball-yellow);border:none;border-radius:10px;padding:14px 24px;cursor:pointer">Join the waitlist</button>
            </form>
          </div>
          <div data-state="success" hidden>
            <div style="font-family:var(--font-display);font-weight:600;font-size:18px;color:var(--tt-ball-yellow)">You're on the list. See you on court.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <WaitlistScript />
</Layout>
