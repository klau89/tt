---
// Shared 4-column footer + bottom bar.
---
<footer style="width:100%;background:var(--tt-honey-cream);border-top:1px solid var(--tt-cream-shade);font-family:var(--font-body)">
  <div style="max-width:1120px;margin:0 auto;padding:48px 24px;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;align-items:start">
    <div>
      <img src="/assets/logo/lockup-horizontal.svg" alt="Tennis Terminal" height="32" style="height:32px;width:auto;display:block" />
      <p style="font-family:var(--font-body);font-size:14px;color:var(--tt-ink-500);margin:16px 0 0;max-width:26ch">Your court, your schedule. No membership. Brooklyn waterfront.</p>
    </div>
    <div>
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-ink-300);margin-bottom:14px">Explore</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        <a class="tt-footlink" href="/how-it-works">How it works</a>
        <a class="tt-footlink" href="/pricing">Pricing</a>
        <a class="tt-footlink" href="/location">Location</a>
        <a class="tt-footlink" href="/events">Events</a>
        <a class="tt-footlink" href="/about">Our story</a>
        <a class="tt-footlink" href="/faq">FAQ</a>
      </div>
    </div>
    <div>
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-ink-300);margin-bottom:14px">Visit</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        <span style="font-family:var(--font-body);font-size:15px;color:var(--tt-ink-700)">Furman St, Brooklyn Waterfront</span>
        <span style="font-family:var(--font-body);font-size:15px;color:var(--tt-ink-700)">Open daily · 7am–11pm</span>
        <a class="tt-footlink" href="mailto:hey@tennisterminal.com">hey@tennisterminal.com</a>
      </div>
    </div>
    <div>
      <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--tt-ink-300);margin-bottom:14px">Follow</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        <a class="tt-footlink" href="#">Instagram</a>
        <a class="tt-footlink" href="#">TikTok</a>
        <a class="tt-footlink" href="/join">Join the waitlist</a>
      </div>
    </div>
  </div>
  <div style="border-top:1px solid var(--tt-border)">
    <div style="max-width:1120px;margin:0 auto;padding:20px 24px;display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap">
      <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--tt-ink-300)">© 2026 Tennis Terminal</span>
      <span style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--tt-ink-300)">Book · Unlock · Play</span>
    </div>
  </div>
</footer>
